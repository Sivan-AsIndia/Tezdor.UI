{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "91409bbb-b865-4879-b6f4-f59581969389"
  },
  "newProjectRoot": "projects",
  "projects": {
    "TezdorAngular_Project": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
               "glob": "**/*",
                "input": "public"
              },
                   {
    "glob": "**/*",
    "input": "src/assets",
    "output": "/assets"
  }
            ],
             "styles": [
              "src/custom-theme.scss",
            "src/assets/css/styles.css",
  "src/styles.css",
    "node_modules/@ng-select/ng-select/themes/default.theme.css",
    "src/assets/css/login/theme.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5000kB",
                  "maximumError": "10MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4000kB",
                  "maximumError": "8000kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "proxyConfig": "proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "TezdorAngular_Project:build:production"
            },
            "development": {
              "buildTarget": "TezdorAngular_Project:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
